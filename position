class Position:

    VALID_COLUMNS = list("abcdefgh")
    VALID_ROWS = list(range(1, 9))

    def __init__(self, column: str, row: int):
        column = column.lower()
        if column not in self.VALID_COLUMNS:
            raise ValueError(f"Invalid column '{column}'. Must be one of {self.VALID_COLUMNS}.")
        if row not in self.VALID_ROWS:
            raise ValueError(f"Invalid row '{row}'. Must be between 1 and 8.")
        self._column = column
        self._row = row

    # Getters / Setters

    @property
    def column(self) -> str:
        """The column letter ('a'–'h')."""
        return self._column

    @column.setter
    def column(self, value: str):
        value = value.lower()
        if value not in self.VALID_COLUMNS:
            raise ValueError(f"Invalid column '{value}'.")
        self._column = value

    @property
    def row(self) -> int:
        """The row number (1–8)."""
        return self._row

    @row.setter
    def row(self, value: int):
        if value not in self.VALID_ROWS:
            raise ValueError(f"Invalid row '{value}'.")
        self._row = value

    # Helper: numeric index of the column (0 = 'a', 7 = 'h')

    @property
    def col_index(self) -> int:
        """Zero-based column index (0 for 'a', 7 for 'h')."""
        return self.VALID_COLUMNS.index(self._column)

    # Dunder methods

    def __str__(self) -> str:
        """Return the position in standard chess notation, e.g. 'e4'."""
        return f"{self._column}{self._row}"

    def __repr__(self) -> str:
        return f"Position('{self._column}', {self._row})"

    def __eq__(self, other) -> bool:
        if not isinstance(other, Position):
            return NotImplemented
        return self._column == other._column and self._row == other._row

    def __hash__(self):
        return hash((self._column, self._row))

# Functional test block — run with: python position.py

if __name__ == "__main__":
    print("=== Functional tests: Position ===\n")

    p1 = Position("e", 4)
    print(f"Position created: {p1}")        # Expected: e4
    assert str(p1) == "e4"

    p2 = Position("A", 1)                  # uppercase should be accepted
    print(f"Position created: {p2}")        # Expected: a1
    assert str(p2) == "a1"

    p3 = Position("h", 8)
    print(f"Position created: {p3}")        # Expected: h8
    assert str(p3) == "h8"

    # Equality
    p4 = Position("e", 4)
    assert p1 == p4, "Equal positions should be equal"
    assert p1 != p2, "Different positions should not be equal"

    # col_index
    assert Position("a", 1).col_index == 0
    assert Position("h", 1).col_index == 7

    # Invalid inputs
    try:
        Position("z", 4)
        assert False, "Should have raised ValueError"
    except ValueError as exc:
        print(f"Caught expected error: {exc}")

    try:
        Position("a", 9)
        assert False, "Should have raised ValueError"
    except ValueError as exc:
        print(f"Caught expected error: {exc}")

    print("\nAll Position tests passed!")