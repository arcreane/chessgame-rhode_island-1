# rook.py
from position import Position
from piece import Piece


class Rook(Piece):
    """
    The Rook piece.

    A rook moves horizontally or vertically.
    """

    def symbol(self) -> str:
        return "R"

    def isValidMove(self, newPosition: Position, board) -> bool:
        current = self.position

        if current is None:
            return False

        same_col = current.column == newPosition.column
        same_row = current.row == newPosition.row

        # Rook must move exactly in one direction:
        # same column OR same row, but not both.
        if same_col == same_row:
            return False

        if not board.isPathClear(current, newPosition):
            return False

        occupant = board.getPiece(newPosition)

        if occupant is not None and occupant.color == self.color:
            return False

        return True


if __name__ == "__main__":
    from board import Board

    print("=== Functional tests: Rook ===\n")

    board = Board(empty=True)

    rook = Rook(Position("a", 1), 0)
    board.placePiece(rook, Position("a", 1))

    assert rook.isValidMove(Position("a", 5), board)
    print("Test 1 passed: a1 -> a5.")

    assert rook.isValidMove(Position("h", 1), board)
    print("Test 2 passed: a1 -> h1.")

    assert not rook.isValidMove(Position("d", 4), board)
    print("Test 3 passed: diagonal move rejected.")

    blocker = Rook(Position("a", 3), 0)
    board.placePiece(blocker, Position("a", 3))

    assert not rook.isValidMove(Position("a", 5), board)
    print("Test 4 passed: blocked path rejected.")

    board.removePiece(blocker)

    enemy = Rook(Position("a", 3), 1)
    board.placePiece(enemy, Position("a", 3))

    assert rook.isValidMove(Position("a", 3), board)
    print("Test 5 passed: enemy capture allowed.")

    own = Rook(Position("h", 1), 0)
    board.placePiece(own, Position("h", 1))

    assert not rook.isValidMove(Position("h", 1), board)
    print("Test 6 passed: own piece capture rejected.")

    print("\nAll Rook tests passed!")
